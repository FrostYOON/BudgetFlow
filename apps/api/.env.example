APP_NAME="BudgetFlow API"
APP_VERSION="0.1.0"
NODE_ENV="development"
PORT=3000
API_PREFIX="api/v1"
SWAGGER_PATH="docs"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/budgetflow?schema=public"
JWT_ACCESS_SECRET="budgetflow-local-access-secret"
JWT_ACCESS_EXPIRES_IN_SECONDS=3600
JWT_REFRESH_SECRET="budgetflow-local-refresh-secret"
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000
PASSWORD_HASH_SALT_ROUNDS=10
