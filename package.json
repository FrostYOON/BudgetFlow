{
  "name": "budgetflow",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "predev": "node ./scripts/check-dev-env.mjs --mode=all",
    "build": "turbo run build",
    "build:api": "pnpm --filter @budgetflow/api build",
    "build:web": "pnpm --filter @budgetflow/web build",
    "dev": "turbo run dev",
    "predev:api": "node ./scripts/check-dev-env.mjs --mode=api",
    "dev:api": "pnpm --filter @budgetflow/api dev",
    "predev:web": "node ./scripts/check-dev-env.mjs --mode=web",
    "dev:web": "pnpm --filter @budgetflow/web dev",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @budgetflow/api lint",
    "test": "turbo run test",
    "test:api": "pnpm --filter @budgetflow/api test -- --runInBand",
    "test:web:e2e": "pnpm --filter @budgetflow/web test:e2e",
    "format": "turbo run format",
    "format:api": "pnpm --filter @budgetflow/api format",
    "docker:start": "docker compose up -d postgres",
    "docker:stop": "docker compose down",
    "docker:logs": "docker compose logs -f postgres",
    "docker:status": "docker compose ps postgres",
    "prisma:format": "pnpm --filter @budgetflow/database prisma:format",
    "prisma:validate": "pnpm --filter @budgetflow/database prisma:validate",
    "prisma:generate": "pnpm --filter @budgetflow/database prisma:generate",
    "prisma:migrate:status": "pnpm --filter @budgetflow/database prisma:migrate:status",
    "prisma:migrate:dev": "pnpm --filter @budgetflow/database exec prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "pnpm --filter @budgetflow/database exec prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:studio": "pnpm --filter @budgetflow/database prisma:studio",
    "data:normalize:starter-categories": "node --env-file=packages/database/.env ./scripts/normalize-starter-category-labels.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.12"
  }
}
